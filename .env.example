# =============================================================
# FitPlan — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env
# =============================================================

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_PASSWORD=mongopassword

# ─── JWT ─────────────────────────────────────────────────────
# Must be at least 32 characters in production
JWT_SECRET=dev-secret-change-in-production-min-32-chars

# ─── SMTP (email sending) ────────────────────────────────────
# Set to mailhog defaults for local dev
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@fitplan.dev

# ─── Google OAuth ────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App URLs ────────────────────────────────────────────────
# On VPS: change to http://<vps-ip>:5173 (or your domain)
# Used by the API for CORS — must match the URL users open in browser
FRONTEND_URL=http://localhost:5173
